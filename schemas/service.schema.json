{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CatalogDoc": {
      "properties": {
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "type"
      ],
      "type": "object"
    },
    "CatalogIssueTracking": {
      "properties": {
        "component": {
          "type": [
            "string",
            "null"
          ]
        },
        "project": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "required": [
        "project",
        "provider"
      ],
      "type": "object"
    },
    "CatalogRepo": {
      "properties": {
        "default_branch": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "default_branch",
        "name",
        "owner",
        "provider",
        "url"
      ],
      "type": "object"
    },
    "UnderstandAnythingConfig": {
      "description": "Point #1 — Understand-Anything artifact configuration.",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "DeployConfig": {
      "description": "Point #8 — Deploy declaration. Either a plain command string OR {skip: true, reason: ...} for repos with no deploy target.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "properties": {
            "skip": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          },
          "required": [
            "skip"
          ],
          "type": "object"
        }
      ]
    }
  },
  "properties": {
    "commands": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "description": {
      "type": "string"
    },
    "docs": {
      "items": {
        "$ref": "#/definitions/CatalogDoc"
      },
      "type": "array"
    },
    "id": {
      "type": "string"
    },
    "issue_tracking": {
      "$ref": "#/definitions/CatalogIssueTracking"
    },
    "kind": {
      "type": "string"
    },
    "likely_relevant_when": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "name": {
      "type": "string"
    },
    "owns": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "products": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "repo": {
      "$ref": "#/definitions/CatalogRepo"
    },
    "team": {
      "type": "string"
    },
    "understand_anything": {
      "description": "Point #1 — Understand-Anything artifact configured.",
      "$ref": "#/definitions/UnderstandAnythingConfig"
    },
    "deploy": {
      "description": "Point #8 — Deploy command string OR {skip: true, reason}.",
      "$ref": "#/definitions/DeployConfig"
    }
  },
  "required": [
    "commands",
    "description",
    "docs",
    "id",
    "issue_tracking",
    "kind",
    "likely_relevant_when",
    "name",
    "owns",
    "products",
    "repo",
    "team"
  ],
  "title": "ServiceCatalog",
  "type": "object"
}
